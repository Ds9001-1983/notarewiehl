---
import { Image } from 'astro:assets';
import { navigation } from '../../data/navigation';
import { kontakt } from '../../data/kontakt';
import MobileNavItem from './MobileNavItem.astro';
import logo from '../../assets/images/logo-kasper.png';

// Leistungs-Icons (für Mega-Menü)
const iconModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/icons/icon-*.png',
  { eager: true }
);
const icon = (key?: string) =>
  key ? iconModules[`../../assets/icons/icon-${key}.png`]?.default : undefined;

const norm = (p: string) => (p.endsWith('/') || /\.[a-z0-9]+$/i.test(p) ? p : p + '/');
const current = norm(Astro.url.pathname);
const isCurrent = (href: string) => norm(href) === current;
const inTrail = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(norm(href));
const panelId = (i: number) => `nav-panel-${i}`;
---

<header class="site-header" data-header transition:name="site-header" transition:animate="none">
  <div class="container header__inner">
    <a class="header__logo" href="/" aria-label={`${kontakt.kanzlei} – Startseite`}>
      <Image src={logo} alt={kontakt.kanzlei} width={350} height={140} densities={[1, 2]} loading="eager" />
    </a>

    <nav class="nav-desktop" aria-label="Hauptnavigation">
      <ul class="nav-desktop__list">
        {
          navigation.map((item, i) => {
            const hasChildren = !!item.children?.length;
            if (!hasChildren) {
              return (
                <li class="nav-item">
                  <a
                    class:list={['nav-item__link', { 'is-trail': inTrail(item.href) }]}
                    href={item.href}
                    aria-current={isCurrent(item.href) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              );
            }
            return (
              <li class:list={['nav-item', 'has-panel', { 'is-mega': item.mega }]}>
                <a
                  class:list={['nav-item__link', { 'is-trail': inTrail(item.href) }]}
                  href={item.href}
                  aria-current={isCurrent(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
                <button
                  class="nav-item__toggle"
                  type="button"
                  aria-expanded="false"
                  aria-controls={panelId(i)}
                  data-toggle
                >
                  <span class="visually-hidden">Untermenü {item.label} öffnen</span>
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
                    <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>

                {item.mega ? (
                  <div class="nav-panel nav-panel--mega" id={panelId(i)} data-panel hidden>
                    <div class="container">
                      <p class="nav-panel__eyebrow">Unsere Tätigkeitsbereiche</p>
                      <ul class="mega__grid">
                        {item.children!.map((c) => (
                          <li class="mega__cell">
                            <a class="mega__card" href={c.href} aria-current={isCurrent(c.href) ? 'page' : undefined}>
                              {icon(c.icon) && (
                                <span class="mega__icon">
                                  <Image src={icon(c.icon)!} alt="" width={48} height={48} />
                                </span>
                              )}
                              <span class="mega__text">
                                <span class="mega__title">{c.label}</span>
                                {c.desc && <span class="mega__desc">{c.desc}</span>}
                              </span>
                            </a>
                            {c.children?.length && (
                              <ul class="mega__sub">
                                {c.children.map((gc) => (
                                  <li>
                                    <a href={gc.href} aria-current={isCurrent(gc.href) ? 'page' : undefined}>
                                      {gc.label}
                                    </a>
                                  </li>
                                ))}
                              </ul>
                            )}
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                ) : (
                  <div class="nav-panel" id={panelId(i)} data-panel hidden>
                    <ul class="dropdown">
                      {item.children!.map((c) => (
                        <li>
                          <a href={c.href} aria-current={isCurrent(c.href) ? 'page' : undefined}>
                            {c.label}
                          </a>
                          {c.children?.length && (
                            <ul class="dropdown__sub">
                              {c.children.map((gc) => (
                                <li>
                                  <a href={gc.href} aria-current={isCurrent(gc.href) ? 'page' : undefined}>
                                    {gc.label}
                                  </a>
                                </li>
                              ))}
                            </ul>
                          )}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </li>
            );
          })
        }
      </ul>
    </nav>

    <a class="header__cta" href="/KONTAKT/">Termin&nbsp;&amp;&nbsp;Kontakt</a>

    <button class="burger" type="button" aria-expanded="false" aria-controls="mobile-drawer" data-burger>
      <span class="visually-hidden">Menü öffnen</span>
      <span class="burger__bars" aria-hidden="true"><span></span><span></span><span></span></span>
    </button>
  </div>
</header>

<!-- Mobile Drawer -->
<div class="drawer-overlay" data-overlay hidden></div>
<aside class="drawer" id="mobile-drawer" data-drawer hidden aria-label="Navigation">
  <div class="drawer__head">
    <span class="drawer__title">Menü</span>
    <button class="drawer__close" type="button" data-close>
      <span class="visually-hidden">Menü schließen</span>
      <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" focusable="false">
        <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
  </div>
  <nav aria-label="Hauptnavigation (mobil)">
    <ul class="mnav">
      {navigation.map((item) => <MobileNavItem node={item} current={current} />)}
    </ul>
  </nav>
  <div class="drawer__contact">
    <a href={kontakt.telefonLink}>{kontakt.telefonAnzeige}</a>
    <a href={kontakt.emailLink}>{kontakt.email}</a>
  </div>
</aside>

<style>
  /* ---------- Header-Grundgerüst ---------- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-subtle);
    transition:
      box-shadow var(--dur-med) var(--ease-out),
      background-color var(--dur-med) var(--ease-out),
      border-bottom-color var(--dur-med) var(--ease-out);
  }
  .site-header.is-scrolled {
    box-shadow: var(--shadow-sm);
  }
  /* Kondensiert: Außenhöhe bleibt konstant (--header-h), nur Logo & Fläche ändern sich */
  .site-header.is-condensed {
    background: rgba(255, 255, 255, 0.95);
    border-bottom-color: transparent;
    box-shadow: var(--shadow-md);
  }
  @supports (backdrop-filter: blur(8px)) {
    .site-header.is-condensed {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px) saturate(1.4);
    }
  }
  .header__inner {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    min-height: var(--header-h);
  }
  .header__logo {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
  }
  .header__logo img {
    width: auto;
    height: 46px;
    transition: height var(--dur-med) var(--ease-out);
  }
  .site-header.is-condensed .header__logo img {
    height: 38px;
  }

  /* ---------- Desktop-Navigation ---------- */
  .nav-desktop {
    margin-left: auto;
  }
  .nav-desktop__list {
    display: flex;
    align-items: center;
    gap: clamp(0.15rem, 0.6vw, 0.45rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
  }
  .nav-item__link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.45rem;
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    border-radius: var(--r-sm);
    white-space: nowrap;
  }
  .dropdown a,
  .mega__sub a { text-decoration: none; }
  .nav-item__link:hover {
    color: var(--c-primary-700);
  }
  .nav-item__link.is-trail {
    color: var(--c-primary-800);
  }
  .nav-item__link[aria-current='page'],
  .nav-item__link.is-trail {
    box-shadow: inset 0 -2px 0 var(--accent);
  }
  .nav-item__toggle {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* BFSG: Klickfläche 24×44px (WCAG 2.5.8: min. 24px; volle 44px Breite sprengen die
       Nav-Zeile unter 1440px), Optik unverändert (Margins kompensieren das Padding);
       flex-shrink 0, sonst staucht die enge Nav-Zeile den Button aufs Padding zusammen */
    flex-shrink: 0;
    padding: 0.8125rem 0.1875rem;
    margin: -0.4625rem 0 -0.4625rem -0.2875rem;
    background: none;
    border: none;
    color: var(--text-muted);
    border-radius: var(--r-sm);
  }
  .nav-item__toggle svg {
    flex-shrink: 0;
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .nav-item__toggle[aria-expanded='true'] svg {
    transform: rotate(180deg);
  }

  /* ---------- Panels ---------- */
  .nav-panel {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    z-index: 90;
    min-width: 250px;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-lg);
    padding: var(--sp-3);
    animation: panelIn var(--dur-med) var(--ease-out);
  }
  .nav-panel[hidden] {
    display: none;
  }
  @keyframes panelIn {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: none; }
  }

  .dropdown,
  .dropdown__sub {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .dropdown > li > a {
    display: block;
    padding: 0.55rem 0.75rem;
    border-radius: var(--r-sm);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .dropdown a:hover {
    background: var(--bg-subtle);
    color: var(--c-primary-800);
  }
  .dropdown a[aria-current='page'] {
    color: var(--c-primary-800);
    font-weight: 600;
  }
  .dropdown__sub {
    margin: 0.1rem 0 0.4rem 0.5rem;
    padding-left: 0.6rem;
    border-left: 1px solid var(--border-subtle);
  }
  .dropdown__sub a {
    display: block;
    padding: 0.4rem 0.75rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: var(--r-sm);
  }

  /* ---------- Mega-Menü ---------- */
  .nav-panel--mega {
    position: fixed;
    left: 0;
    right: 0;
    top: var(--header-h);
    min-width: 0;
    border-radius: 0 0 var(--r-lg) var(--r-lg);
    border-top: 2px solid var(--c-accent-500);
    border-left: none;
    border-right: none;
    padding-block: var(--sp-6);
  }
  .nav-panel__eyebrow {
    font-size: var(--fs-small);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-text);
    margin-bottom: var(--sp-4);
  }
  .mega__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--sp-3) var(--sp-5);
  }
  /* Karten-Stagger beim Öffnen (max. 8 Kinder) */
  .mega__cell {
    animation: cardIn var(--dur-med) var(--ease-out) backwards;
  }
  .mega__cell:nth-child(2) { animation-delay: 30ms; }
  .mega__cell:nth-child(3) { animation-delay: 60ms; }
  .mega__cell:nth-child(4) { animation-delay: 90ms; }
  .mega__cell:nth-child(5) { animation-delay: 120ms; }
  .mega__cell:nth-child(6) { animation-delay: 150ms; }
  .mega__cell:nth-child(7) { animation-delay: 180ms; }
  .mega__cell:nth-child(8) { animation-delay: 210ms; }
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: none; }
  }
  .mega__card {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
    padding: var(--sp-3);
    border-radius: var(--r-md);
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .mega__card:hover {
    background: var(--bg-subtle);
  }
  .mega__icon {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: var(--r-md);
    background: var(--c-primary-050);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .mega__card:hover .mega__icon,
  .mega__card:focus-visible .mega__icon {
    background: var(--c-accent-100);
  }
  .mega__icon img {
    width: 34px;
    height: 34px;
  }
  .mega__title {
    display: block;
    color: var(--c-primary-800);
    font-weight: 600;
    margin-bottom: 0.1rem;
  }
  .mega__desc {
    display: block;
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.4;
  }
  .mega__sub {
    list-style: none;
    margin: 0.2rem 0 0.4rem calc(52px + var(--sp-4) + var(--sp-3));
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem 0.9rem;
  }
  .mega__sub a {
    font-size: 0.82rem;
    color: var(--text-muted);
    text-decoration: none;
  }
  .mega__sub a:hover {
    color: var(--accent-text);
    text-decoration: underline;
  }

  /* ---------- CTA + Burger ---------- */
  .header__cta {
    flex: 0 0 auto;
    display: none;
    padding: 0.6rem 1.1rem;
    background: var(--c-primary-500);
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: var(--r-pill);
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .header__cta:hover {
    background: var(--c-primary-600);
    color: #fff;
  }
  .burger {
    flex: 0 0 auto;
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    background: none;
    border: 1px solid var(--border-subtle);
    border-radius: var(--r-md);
    color: var(--c-primary-800);
  }
  .burger__bars {
    position: relative;
    width: 22px;
    height: 16px;
  }
  .burger__bars span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: transform var(--dur-fast) var(--ease-out), opacity var(--dur-fast);
  }
  .burger__bars span:nth-child(1) { top: 0; }
  .burger__bars span:nth-child(2) { top: 7px; }
  .burger__bars span:nth-child(3) { top: 14px; }
  .burger[aria-expanded='true'] .burger__bars span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger[aria-expanded='true'] .burger__bars span:nth-child(2) { opacity: 0; }
  .burger[aria-expanded='true'] .burger__bars span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ---------- Drawer (mobil) ---------- */
  .drawer-overlay {
    position: fixed;
    inset: 0;
    z-index: 105;
    background: rgba(15, 45, 64, 0.5);
    animation: fadeIn var(--dur-med) var(--ease-out);
  }
  .drawer-overlay[hidden] { display: none; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 110;
    width: min(420px, 92vw);
    height: 100dvh;
    background: var(--bg-surface);
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    overscroll-behavior: contain;
    animation: drawerIn var(--dur-med) var(--ease-out);
  }
  .drawer[hidden] { display: none; }
  @keyframes drawerIn { from { transform: translateX(100%); } to { transform: none; } }

  .drawer__head {
    position: sticky;
    top: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-primary-800);
    color: #fff;
  }
  .drawer__title { font-weight: 600; letter-spacing: 0.04em; }
  .drawer__close {
    display: inline-flex;
    background: none;
    border: none;
    color: #fff;
    padding: 4px;
    border-radius: var(--r-sm);
  }

  .mnav {
    list-style: none;
    margin: 0;
    padding: var(--sp-3) var(--sp-4) var(--sp-5);
  }

  .drawer__contact {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: var(--sp-5);
    background: var(--bg-subtle);
    font-weight: 600;
  }
  .drawer__contact a { color: var(--c-primary-700); text-decoration: none; }

  /* ---------- Responsive Umschaltung ---------- */
  .burger { display: inline-flex; }
  .nav-desktop { display: none; }

  /* 1280px: darunter passt die volle Desktop-Nav nicht in die Zeile
     (Items würden gestaucht/abgeschnitten) – dann Burger-Drawer */
  @media (min-width: 1280px) {
    .burger { display: none; }
    .nav-desktop { display: block; }
    .header__cta { display: inline-flex; }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-panel,
    .drawer,
    .drawer-overlay,
    .mega__cell { animation: none; } /* .mega__cell nötig: globaler Kill lässt animation-delay stehen */
  }
</style>

<script>
  import './nav.client.ts';
</script>
