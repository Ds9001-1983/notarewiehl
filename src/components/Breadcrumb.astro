---
import { getBreadcrumbs } from '../lib/breadcrumbs';

interface Props {
  currentLabel?: string;
}
const { currentLabel } = Astro.props;
const crumbs = getBreadcrumbs(Astro.url.pathname, currentLabel);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    item: new URL(c.href, Astro.site).toString(),
  })),
};
---

{
  crumbs.length > 1 && (
    <nav class="breadcrumb" aria-label="Sie befinden sich hier:">
      <ol>
        {crumbs.map((c) => (
          <li>
            {c.current ? (
              <span aria-current="page">{c.label}</span>
            ) : (
              <a href={c.href}>{c.label}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  )
}

<style>
  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--fs-small);
    color: var(--text-muted);
  }
  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .breadcrumb li + li::before {
    content: '›';
    color: var(--c-neutral-300);
  }
  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--accent-text);
    text-decoration: underline;
  }
  .breadcrumb [aria-current='page'] {
    color: var(--text-secondary);
    font-weight: 500;
  }
</style>
