---
interface Item {
  label: string;
  href: string;
  desc?: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<ul class="sublinks">
  {
    items.map((i) => (
      <li>
        <a class="sublink" href={i.href}>
          <span class="sublink__text">
            <span class="sublink__title">{i.label}</span>
            {i.desc && <span class="sublink__desc">{i.desc}</span>}
          </span>
          <span class="sublink__arrow" aria-hidden="true">→</span>
        </a>
      </li>
    ))
  }
</ul>

<style>
  .sublinks {
    list-style: none;
    margin: var(--sp-5) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--sp-4);
  }
  .sublink {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    height: 100%;
    padding: var(--sp-5);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition: transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  }
  .sublink:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--c-primary-300);
  }
  .sublink__title { display: block; font-weight: 600; color: var(--c-primary-800); }
  .sublink__desc { display: block; margin-top: 0.2rem; font-size: 0.9rem; color: var(--text-muted); }
  .sublink__arrow { color: var(--accent); font-size: 1.2rem; }
</style>
