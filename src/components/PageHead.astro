---
import Breadcrumb from './Breadcrumb.astro';

interface Props {
  title: string;
  lead?: string;
}
const { title, lead } = Astro.props;
---

<section class="page-head">
  <div class="container">
    <Breadcrumb />
    <h1>{title}</h1>
    {lead && <p class="page-head__lead">{lead}</p>}
  </div>
</section>

<style>
  .page-head {
    background: linear-gradient(180deg, var(--c-primary-050), var(--bg-page));
    border-bottom: 1px solid var(--border-subtle);
    padding-block: var(--sp-6) var(--sp-7);
  }
  .page-head h1 {
    margin-top: var(--sp-4);
    max-width: 24ch;
  }
  .page-head h1::after {
    content: '';
    display: block;
    width: 64px;
    height: 3px;
    margin-top: var(--sp-4);
    background: var(--accent);
    border-radius: 2px;
  }
  .page-head__lead {
    margin-top: var(--sp-4);
    max-width: var(--measure-narrow);
    font-size: var(--fs-lead);
    color: var(--text-secondary);
  }
</style>
