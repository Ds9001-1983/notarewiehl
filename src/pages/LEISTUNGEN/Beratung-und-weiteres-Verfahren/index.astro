---
import TextPageLayout from '@/layouts/TextPageLayout.astro';
import LeistungenGrid from '@/components/LeistungenGrid.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('leistungen', 'beratung-und-weiteres-verfahren');
if (!entry) throw new Error('Fehlender Inhalt: leistungen/beratung-und-weiteres-verfahren');
const { Content } = await render(entry);
---

<TextPageLayout title={entry.data.title} description={entry.data.description} lead={entry.data.lead}>
  <Content />
  <section slot="after" class="section section--subtle">
    <div class="container">
      <LeistungenGrid exclude={Astro.url.pathname} eyebrow="Weitere Bereiche" heading="Weitere Leistungen" />
    </div>
  </section>
</TextPageLayout>
