---
import TextPageLayout from '@/layouts/TextPageLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('seiten', 'register');
if (!entry) throw new Error('Fehlender Inhalt: seiten/register');
const { Content } = await render(entry);
---

<TextPageLayout title={entry.data.title} description={entry.data.description} lead={entry.data.lead}>
  <Content />
</TextPageLayout>
