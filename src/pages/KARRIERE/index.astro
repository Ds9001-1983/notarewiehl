---
import TextPageLayout from '@/layouts/TextPageLayout.astro';
import BewerberFunnel from '@/components/BewerberFunnel.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('seiten', 'karriere');
if (!entry) throw new Error('Fehlender Inhalt: seiten/karriere');
const { Content } = await render(entry);
---

<TextPageLayout title={entry.data.title} description={entry.data.description} lead={entry.data.lead}>
  <Content />
  <section slot="after" class="section section--subtle" id="bewerbung">
    <div class="container">
      <BewerberFunnel />
    </div>
  </section>
</TextPageLayout>
