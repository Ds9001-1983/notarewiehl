---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Seite nicht gefunden" description="Die aufgerufene Seite wurde nicht gefunden." noindex={true}>
  <section class="section">
    <div class="container nf">
      <p class="nf__code">404</p>
      <h1>Seite nicht gefunden</h1>
      <p>
        Die aufgerufene Seite existiert nicht (mehr). Vielleicht hilft Ihnen einer der folgenden
        Links weiter:
      </p>
      <div class="nf__links">
        <a class="btn btn--primary" href="/">Zur Startseite</a>
        <a class="btn btn--ghost" href="/LEISTUNGEN/">Leistungen</a>
        <a class="btn btn--ghost" href="/KONTAKT/">Kontakt</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { max-width: 60ch; text-align: center; margin-inline: auto; padding-block: var(--sp-7); }
  .nf__code {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 10vw, 6rem);
    color: var(--c-primary-200);
    line-height: 1;
  }
  .nf h1 { margin-bottom: var(--sp-4); }
  .nf p { color: var(--text-secondary); margin-bottom: var(--sp-5); }
  .nf__links { display: flex; flex-wrap: wrap; gap: var(--sp-4); justify-content: center; }
</style>
