---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Seite nicht gefunden" description="Die aufgerufene Seite wurde nicht gefunden." noindex={true}>
  <section class="section">
    <div class="container nf">
      <p class="nf__code">404</p>
      <h1>Seite nicht gefunden</h1>
      <p>
        Die aufgerufene Seite existiert nicht (mehr). Vielleicht hilft Ihnen einer der folgenden
        Links weiter:
      </p>
      <div class="nf__links">
        <a class="btn btn--primary" href="/">Zur Startseite</a>
        <a class="btn btn--ghost" href="/LEISTUNGEN/">Leistungen</a>
        <a class="btn btn--ghost" href="/KONTAKT/">Kontakt</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { max-width: 60ch; text-align: center; margin-inline: auto; padding-block: var(--sp-7); }
  .nf__code {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 10vw, 6rem);
    color: var(--c-primary-200);
    line-height: 1;
    animation: nf-rise 500ms var(--ease-out) both;
  }
  .nf h1 {
    margin-bottom: var(--sp-4);
    animation: nf-rise 500ms var(--ease-out) 100ms both;
  }
  .nf h1::after {
    content: '';
    display: block;
    width: 64px;
    height: 3px;
    margin: var(--sp-4) auto 0;
    background: var(--accent);
    border-radius: 2px;
    animation: nf-draw 500ms var(--ease-out) 350ms both;
  }
  .nf p {
    color: var(--text-secondary);
    margin-bottom: var(--sp-5);
    animation: nf-rise 500ms var(--ease-out) 200ms both;
  }
  .nf__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    justify-content: center;
    animation: nf-rise 500ms var(--ease-out) 300ms both;
  }

  /* Einblenden wie PageHead; Reduced Motion springt via globalen Kill in den Endzustand */
  @keyframes nf-rise {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes nf-draw {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }
</style>
