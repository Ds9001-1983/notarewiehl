---
import '@fontsource-variable/rubik';
import '@fontsource-variable/lora';
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/prose.css';

import { ClientRouter } from 'astro:transitions';
import Seo from '../components/Seo.astro';
import Header from '../components/nav/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}
const { title, description, image, noindex } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#143c55" />
    <Seo title={title} description={description} image={image} noindex={noindex} />
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main">Zum Inhalt springen</a>
    <Header />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <script>
      import '../lib/reveal.ts';
    </script>
  </body>
</html>
